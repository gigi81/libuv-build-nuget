<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
    <metadata>
        <id>libuv-shared</id>
        <version>0.0.1-ignored</version>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>libuv shared library packge with native runtime for Windows (x64/x86/arm64), Linux (x64/arm64/arm/armel) and Osx (x64/arm64). CHeck the release notes for more details</description>
        <authors>Luigi Grilli</authors>
        <license type="file">LICENSE</license>
        <releaseNotes></releaseNotes>
        <projectUrl>https://github.com/gigi81/libuv-build-nuget</projectUrl>
        <repository type="git" url="https://github.com/gigi81/libuv-build-nuget.git" />
    </metadata>
  <files>
    <file src="runtimes\**" target="runtimes" />
	<file src="libuv\LICENS*" target="" />
  </files>
</package>
